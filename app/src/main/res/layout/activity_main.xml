<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/window_background">

    <!-- DISPLAY AREA: top 35% of screen -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="35"
        android:gravity="bottom"
        android:paddingLeft="24dp"
        android:paddingRight="24dp"
        android:paddingBottom="16dp"
        android:background="@color/io_background"
        android:orientation="vertical">

        <!-- What you typed -->
        <TextView
            android:id="@+id/input"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="32sp"
            android:textColor="#8E8E93"
            android:maxLines="2"
            android:ellipsize="start" />

        <!-- Live result -->
        <TextView
            android:id="@+id/output"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end"
            android:textSize="64sp"
            android:textStyle="bold"
            android:textColor="@color/text_main"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- BUTTON GRID: bottom 65% of screen -->
    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="65"
        android:stretchColumns="*"
        android:paddingLeft="8dp"
        android:paddingRight="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Row 1: C  ()  %  ÷ -->
        <TableRow android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <Button android:id="@+id/buttonClear"    style="@style/CalculatorButton.Function"  android:text="C"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/buttonBracket"  style="@style/CalculatorButton.Function"  android:text="( )"  android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/buttonPercent"  style="@style/CalculatorButton.Function"  android:text="%"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/buttonDivide"   style="@style/CalculatorButton.Operator"  android:text="÷"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
        </TableRow>

        <!-- Row 2: 7  8  9  × -->
        <TableRow android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <Button android:id="@+id/button7"        style="@style/CalculatorButton.Number"    android:text="7"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/button8"        style="@style/CalculatorButton.Number"    android:text="8"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/button9"        style="@style/CalculatorButton.Number"    android:text="9"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/buttonMultiply" style="@style/CalculatorButton.Operator"  android:text="×"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
        </TableRow>

        <!-- Row 3: 4  5  6  − -->
        <TableRow android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <Button android:id="@+id/button4"        style="@style/CalculatorButton.Number"    android:text="4"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/button5"        style="@style/CalculatorButton.Number"    android:text="5"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/button6"        style="@style/CalculatorButton.Number"    android:text="6"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/buttonMinus"    style="@style/CalculatorButton.Operator"  android:text="−"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
        </TableRow>

        <!-- Row 4: 1  2  3  + -->
        <TableRow android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <Button android:id="@+id/button1"        style="@style/CalculatorButton.Number"    android:text="1"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/button2"        style="@style/CalculatorButton.Number"    android:text="2"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/button3"        style="@style/CalculatorButton.Number"    android:text="3"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/buttonPlus"     style="@style/CalculatorButton.Operator"  android:text="+"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
        </TableRow>

        <!-- Row 5: .  0  ⌫  = -->
        <TableRow android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
            <Button android:id="@+id/buttonDot"      style="@style/CalculatorButton.Number"    android:text="."    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/button0"        style="@style/CalculatorButton.Number"    android:text="0"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/buttonDelete"   style="@style/CalculatorButton.Function"  android:text="⌫"    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
            <Button android:id="@+id/buttonEquals"   style="@style/CalculatorButton.Operator"  android:text="="    android:layout_width="0dp" android:layout_weight="1" android:layout_height="match_parent"/>
        </TableRow>

    </TableLayout>

</LinearLayout>